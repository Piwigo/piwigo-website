
      <div class="contact-form-card">
        <form class="contact-form-card-form" action="#" method="post" onsubmit="return false;">
          <input type="email" class="form-control" placeholder="Your email address*" aria-label="Your email address">
          <input type="text" class="form-control" placeholder="Your Piwigo url (if you are already a Piwigo user)" aria-label="Your Piwigo url">
          <textarea class="form-control" rows="8" placeholder="Your message*" aria-label="Your message"></textarea>
          <div class="text-end">
            <button type="submit" class="btn contact-form-card-submit">Send message</button>
          </div>
        </form>
      </div>
    </div>
